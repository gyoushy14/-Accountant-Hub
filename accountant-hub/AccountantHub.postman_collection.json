{
  "info": {
    "name": "Accountant Hub API",
    "description": "REST API for the Accountant Hub freelance marketplace. All endpoints are prefixed with /api/v1.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"New Accountant\",\n    \"email\": \"new@test.com\",\n    \"password\": \"password\",\n    \"password_confirmation\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"accountant1@test.com\",\n    \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs (Default)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/jobs",
              "host": ["{{base_url}}"],
              "path": ["jobs"]
            }
          }
        },
        {
          "name": "List Jobs (Filtered & Sorted)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/jobs?search=bookkeeping&category_id=1&budget_min=500&budget_max=5000&sort=highest_budget&status=open",
              "host": ["{{base_url}}"],
              "path": ["jobs"],
              "query": [
                { "key": "search", "value": "bookkeeping" },
                { "key": "category_id", "value": "1" },
                { "key": "budget_min", "value": "500" },
                { "key": "budget_max", "value": "5000" },
                { "key": "sort", "value": "highest_budget" },
                { "key": "status", "value": "open" }
              ]
            }
          }
        },
        {
          "name": "Get Job Detail (Authenticated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/jobs/1",
              "host": ["{{base_url}}"],
              "path": ["jobs", "1"]
            }
          }
        },
        {
          "name": "Get Job Detail (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/jobs/2",
              "host": ["{{base_url}}"],
              "path": ["jobs", "2"]
            }
          }
        }
      ]
    },
    {
      "name": "Bids",
      "item": [
        {
          "name": "Submit Bid",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"proposed_price\": 1200,\n    \"estimated_delivery_time\": \"2 weeks\",\n    \"cover_letter\": \"I am a certified accountant with 6 years of experience in this area. I can deliver high-quality work on time.\",\n    \"experience_summary\": \"6+ years of accounting experience specializing in bookkeeping and financial reporting for small to medium businesses.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/jobs/5/bids",
              "host": ["{{base_url}}"],
              "path": ["jobs", "5", "bids"]
            }
          }
        },
        {
          "name": "Submit Duplicate Bid (Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"proposed_price\": 800,\n    \"estimated_delivery_time\": \"1 week\",\n    \"cover_letter\": \"I am a certified accountant with experience in this exact area. I can deliver quickly.\",\n    \"experience_summary\": \"5 years experience in accounting and financial management.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/jobs/1/bids",
              "host": ["{{base_url}}"],
              "path": ["jobs", "1", "bids"]
            }
          }
        },
        {
          "name": "Get My Bids",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/my-bids",
              "host": ["{{base_url}}"],
              "path": ["my-bids"]
            }
          }
        }
      ]
    }
  ]
}
